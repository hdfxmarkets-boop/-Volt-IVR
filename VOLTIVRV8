.expand-btn{background:none;border:none;font-size:10px;color:var(--g);cursor:pointer;padding:0;font-weight:700}
.check-detail{padding:12px 14px;background:var(--b2);border-radius:7px;border:1px solid var(--bdr);font-size:11px;line-height:1.7;color:var(--tx2)}
