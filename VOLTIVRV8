      <span style="font-size:15px;font-weight:800;color:var(--g);letter-spacing:0.5px">Volt IVR</span>
    </div>
    <div class="topbar-divider"></div>
    <div style="font-size:12px;font-weight:600;color:var(--tx2);display:flex;align-items:center;gap:6px">🏢 <span id="tenant-name">Your Company</span></div>
