function extractPdfText(file){
  return new Promise(function(resolve,reject){
    if(!window.pdfjsLib){reject(new Error('PDF engine unavailable'));return;}
    var reader=new FileReader();
    reader.onload=function(){
      pdfjsLib.getDocument({data:new Uint8Array(reader.result)}).promise.then(function(pdf){
        var pages=[];
        var loadPage=function(n){
          return pdf.getPage(n).then(function(page){return page.getTextContent();}).then(function(tc){
            pages.push(tc.items.map(function(it){return it.str;}).join(' '));
          });
        };
        var chain=Promise.resolve();
        for(var i=1;i<=pdf.numPages;i++){(function(n){chain=chain.then(function(){return loadPage(n);});})(i);}
        chain.then(function(){resolve(pages.join('\n'));}).catch(reject);
      }).catch(reject);
    };
    reader.onerror=reject;
    reader.readAsArrayBuffer(file);
  });
}

function numFrom(str){if(!str)return null;var n=parseFloat(str.replace(/,/g,''));return isNaN(n)?null:n;}
function firstMatch(text,patterns){
  for(var i=0;i<patterns.length;i++){
    var m=text.match(patterns[i]);
    if(m&&m[1]!==undefined)return m[1];
  }
  return null;
}
function firstDate(text,patterns){
  var raw=firstMatch(text,patterns);
  if(!raw)return null;
  var m=raw.match(/(\d{1,2})[\/\-\.](\d{1,2})[\/\-\.](\d{2,4})/);
  if(m){var yy=m[3].length===2?'20'+m[3]:m[3];return yy+'-'+m[2].padStart(2,'0')+'-'+m[1].padStart(2,'0');}
  var m2=raw.match(/(\d{4})[\/\-](\d{1,2})[\/\-](\d{1,2})/);
  if(m2)return m2[1]+'-'+m2[2].padStart(2,'0')+'-'+m2[3].padStart(2,'0');
  return null;
}

function parseInvoiceFields(text){
  var f={};
  f.invnum=firstMatch(text,[/invoice\s*(?:no\.?|number|ref(?:erence)?)\s*[:\-]?\s*([A-Z0-9][A-Z0-9\-\/]{3,})/i]);
  f.mpan=firstMatch(text,[/MPAN\s*[:\-]?\s*([0-9\s]{10,25})/i]);
  f.mprn=firstMatch(text,[/MPRN\s*[:\-]?\s*([0-9]{6,12})/i]);
  f.invdate=firstDate(text,[/invoice\s*date\s*[:\-]?\s*([0-9\/\.\-]{6,10})/i,/bill\s*date\s*[:\-]?\s*([0-9\/\.\-]{6,10})/i]);
  f.pstart=firstDate(text,[/(?:period|from)\s*[:\-]?\s*([0-9]{1,2}[\/\-\.][0-9]{1,2}[\/\-\.][0-9]{2,4})\s*(?:to|-|–)/i]);
  f.pend=firstDate(text,[/(?:to|-|–)\s*([0-9]{1,2}[\/\-\.][0-9]{1,2}[\/\-\.][0-9]{2,4})\s*(?:\(|$|days)/i]);
  f.kwh=numFrom(firstMatch(text,[/total\s*(?:consumption|usage)?\s*[:\-]?\s*([\d,]+(?:\.\d+)?)\s*kwh/i,/([\d,]+(?:\.\d+)?)\s*kwh/i]));
  f.unitrate=numFrom(firstMatch(text,[/unit\s*rate\s*[:\-]?\s*([\d.]+)\s*p(?:ence)?\s*\/?\s*kwh/i,/([\d.]+)\s*p(?:ence)?\s*\/\s*kwh/i]));
  f.standing=numFrom(firstMatch(text,[/standing\s*charge\s*[:\-]?\s*([\d.]+)\s*p(?:ence)?/i]));
  f.ccl=numFrom(firstMatch(text,[/(?:CCL|climate\s*change\s*levy)[^£\d]{0,20}£\s*([\d,]+\.\d{2})/i]));
  f.vat=numFrom(firstMatch(text,[/\bVAT\b[^£\d]{0,20}£\s*([\d,]+\.\d{2})/i]));
  f.total=numFrom(firstMatch(text,[/total\s*(?:amount\s*)?(?:due|payable)\s*[:\-]?\s*£\s*([\d,]+\.\d{2})/i,/amount\s*due\s*[:\-]?\s*£\s*([\d,]+\.\d{2})/i]));
  f.supplier=firstMatch(text,[/(British Gas Business|EDF Energy|E\.?ON|Npower|SSE|Scottish Power|Opus Energy|Corona Energy|Yorkshire Water|Total Gas & Power|Total Energies|Drax|Gazprom)/i]);
  f.utype=/\bgas\b/i.test(text)&&!/electric/i.test(text)?'Gas':/water/i.test(text)&&!/electric/i.test(text)?'Water':'Electricity';
  return f;
}

function parseContractFields(text){
  var f={};
  f.unitrate=numFrom(firstMatch(text,[/unit\s*rate\s*[:\-]?\s*([\d.]+)\s*p(?:ence)?\s*\/?\s*kwh/i,/([\d.]+)\s*p(?:ence)?\s*\/\s*kwh/i]));
  f.standing=numFrom(firstMatch(text,[/standing\s*charge\s*[:\-]?\s*([\d.]+)\s*p(?:ence)?/i]));
  f.start=firstDate(text,[/contract\s*(?:start|commencement)\s*(?:date)?\s*[:\-]?\s*([0-9\/\.\-]{6,10})/i]);
  f.end=firstDate(text,[/contract\s*(?:end|expiry)\s*(?:date)?\s*[:\-]?\s*([0-9\/\.\-]{6,10})/i]);
  return f;
}

