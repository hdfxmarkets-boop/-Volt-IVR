var CCL_RATES={'Electricity':0.775,'Gas':0.2685,'Water':0};

function money(n){return '£'+n.toLocaleString('en-GB',{minimumFractionDigits:2,maximumFractionDigits:2});}

function runRealValidation(){
  var g=function(id){var el=document.getElementById(id);return el?el.value:'';};
  var num=function(id){var v=parseFloat(g(id));return isNaN(v)?null:v;};
  var kwh=num('f-kwh'),unitrate=num('f-unitrate'),standing=num('f-standing'),ccl=num('f-ccl'),vat=num('f-vat'),total=num('f-total');
  var utype=g('f-utype'),invnum=g('f-invnum')||'(no invoice number entered)',acctref=g('f-acctref')||'(no account ref)',supplier=g('f-supplier')||'(no supplier entered)';
  var pstart=g('f-pstart'),pend=g('f-pend');
  var errEl=document.getElementById('run-validation-error'),errMsg=document.getElementById('run-validation-error-msg');
  var missing=[];
  if(kwh===null)missing.push('Total kWh');
  if(unitrate===null)missing.push('Unit rate billed');
  if(total===null)missing.push('Total cost billed');
  if(vat===null)missing.push('Total VAT');
  if(missing.length){
    errEl.style.display='flex';errMsg.innerHTML='Can\'t run a real calculation without: <strong>'+missing.join(', ')+'</strong>. Fill these in from the invoice (or enter your best figure) and try again.';
    return;
  }
  errEl.style.display='none';
  var days=null;
  if(pstart&&pend){var d1=new Date(pstart),d2=new Date(pend);days=Math.round((d2-d1)/86400000)+1;if(days<=0||days>400)days=null;}
  if(!days)days=90;
  standing=standing===null?0:standing;
  ccl=ccl===null?0:ccl;

  var results=[];
  var idc=1;
  var overcharge=0;

  var energyCost=kwh*unitrate/100;
  var standingCost=standing/100*days;
  var expectedTotalExVat=energyCost+standingCost+ccl;
  var expectedTotal=expectedTotalExVat+vat;
  var totalDiff=total-expectedTotal;
  results.push({id:idc++,name:'Total Cost Recalculation',cat:'Financial',
    status:Math.abs(totalDiff)<=0.5?'pass':Math.abs(totalDiff)<=10?'warning':'error',
    detail:'Recalculated from confirmed figures: '+kwh.toLocaleString()+' kWh × '+unitrate+'p + standing charge ('+standing+'p × '+days+' days) + '+money(ccl)+' CCL + '+money(vat)+' VAT = '+money(expectedTotal)+'. Billed: '+money(total)+'. Difference: '+(totalDiff>=0?'+':'')+money(totalDiff)+ (days?'. (Billing period assumed '+days+' days'+(pstart&&pend?'':' — no period dates entered, default used')+'.)':'')});
  if(totalDiff>0)overcharge+=totalDiff;

  var expectedVat=expectedTotalExVat*0.20;
  var vatDiff=vat-expectedVat;
  results.push({id:idc++,name:'VAT Recalculation',cat:'Tax & Levy',
    status:Math.abs(vatDiff)<=0.5?'pass':Math.abs(vatDiff)<=5?'warning':'error',
    detail:'Expected VAT at standard 20% on '+money(expectedTotalExVat)+' net = '+money(expectedVat)+'. Billed VAT: '+money(vat)+'. Difference: '+(vatDiff>=0?'+':'')+money(vatDiff)+'. (Assumes standard-rate VAT — if this supply qualifies for the 5% reduced rate, this check will show a false variance.)'});
  if(vatDiff>0)overcharge+=vatDiff;

  if(utype==='Electricity'||utype==='Gas'){
    var cclRate=CCL_RATES[utype];
    var expectedCcl=kwh*cclRate/100;
    var cclDiff=ccl-expectedCcl;
    results.push({id:idc++,name:'Climate Change Levy Check',cat:'Tax & Levy',
      status:Math.abs(cclDiff)<=0.5?'pass':Math.abs(cclDiff)<=5?'warning':'error',
      detail:'Expected CCL at main rate '+cclRate+'p/kWh × '+kwh.toLocaleString()+' kWh = '+money(expectedCcl)+'. Billed CCL: '+money(ccl)+'. Difference: '+(cclDiff>=0?'+':'')+money(cclDiff)+'. (Uses the main CCL rate — if this account holds a CCL exemption/reduction certificate, expect a variance here.)'});
    if(cclDiff>0)overcharge+=cclDiff;
  } else {
    results.push({id:idc++,name:'Climate Change Levy Check',cat:'Tax & Levy',status:'pass',detail:'CCL does not apply to water supplies — skipped.'});
  }

  var cUnit=num('c-unitrate'),cStanding=num('c-standing'),cStart=g('c-start'),cEnd=g('c-end');
  if(cUnit!==null){
    var rateDiff=unitrate-cUnit;
    var rateImpact=rateDiff*kwh/100;
    results.push({id:idc++,name:'Contract Unit Rate Check',cat:'Tariff',
      status:Math.abs(rateDiff)<=0.01?'pass':Math.abs(rateDiff)<=0.2?'warning':'error',
      detail:'Contract rate: '+cUnit+'p/kWh. Billed rate: '+unitrate+'p/kWh. Difference: '+(rateDiff>=0?'+':'')+rateDiff.toFixed(3)+'p/kWh × '+kwh.toLocaleString()+' kWh = '+(rateImpact>=0?'+':'')+money(rateImpact)+' impact on this invoice.'});
    if(rateImpact>0)overcharge+=rateImpact;
  } else {
    results.push({id:idc++,name:'Contract Unit Rate Check',cat:'Tariff',status:'warning',detail:'No contract unit rate entered — upload the supply contract or enter its rate manually to enable this check.'});
  }
  if(cStanding!==null){
    var stDiff=standing-cStanding;
    var stImpact=stDiff/100*days;
    results.push({id:idc++,name:'Contract Standing Charge Check',cat:'Tariff',
      status:Math.abs(stDiff)<=0.01?'pass':Math.abs(stDiff)<=1?'warning':'error',
      detail:'Contract standing charge: '+cStanding+'p/day. Billed: '+standing+'p/day. Difference: '+(stDiff>=0?'+':'')+stDiff.toFixed(3)+'p/day × '+days+' days = '+(stImpact>=0?'+':'')+money(stImpact)+' impact.'});
    if(stImpact>0)overcharge+=stImpact;
  } else {
    results.push({id:idc++,name:'Contract Standing Charge Check',cat:'Tariff',status:'warning',detail:'No contract standing charge entered — upload the supply contract or enter it manually to enable this check.'});
  }
  if(cStart&&cEnd&&pstart){
    var withinTerm=pstart>=cStart&&pstart<=cEnd;
    results.push({id:idc++,name:'Billing Period vs Contract Term',cat:'Account Matching',
      status:withinTerm?'pass':'error',
      detail:'Contract term: '+cStart+' to '+cEnd+'. Invoice period starts '+pstart+'. '+(withinTerm?'Falls within the contract term.':'Falls OUTSIDE the contract term — invoice may be on out-of-contract (deemed) rates, which are typically much higher.')});
  }

  results.push({id:idc++,name:'Consumption Present',cat:'Consumption',status:kwh>0?'pass':'error',detail:kwh>0?'Consumption of '+kwh.toLocaleString()+' kWh recorded for the period.':'Zero or missing consumption recorded — cannot validate a zero-usage bill.'});

  checks=results;
  currentInvoiceMeta={invnum:invnum,acctref:acctref,supplier:supplier};
  lastOvercharge=overcharge;

  results.forEach(function(r){allChecks.push({cat:r.cat,status:r.status,invId:invnum});});

  var errN=results.filter(function(r){return r.status==='error';}).length;
  var warnN=results.filter(function(r){return r.status==='warning';}).length;
  var passN=results.filter(function(r){return r.status==='pass';}).length;

  var typeMap={'Electricity':{type:'elec',icon:'⚡'},'Gas':{type:'gas',icon:'🔥'},'Water':{type:'water',icon:'💧'}};
  var tinfo=typeMap[utype]||typeMap['Electricity'];
  var dateLabel=g('f-invdate')?new Date(g('f-invdate')).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}):'(no date entered)';
  var invEntry={id:invnum,site:acctref,type:tinfo.type,icon:tinfo.icon,supplier:supplier,date:dateLabel,amount:money(total),errors:errN,warnings:warnN,passed:passN,overcharge:overcharge};
  var existingIdx=invoices.findIndex(function(i){return i.id===invnum;});
  if(existingIdx>=0)invoices[existingIdx]=invEntry;else invoices.unshift(invEntry);

  var mpan=g('f-mpan');
  var acctEntry={ref:acctref,site:acctref,mpan:mpan||'—',type:utype,supplier:supplier,tariff:'—',contract:cUnit!==null?'Loaded':'—',status:'Active'};
  var acctIdx=accounts.findIndex(function(a){return a.ref===acctref;});
  if(acctIdx>=0)accounts[acctIdx]=acctEntry;else accounts.push(acctEntry);

  if(g('f-invdate')){
    var mLabel=new Date(g('f-invdate')).toLocaleDateString('en-GB',{month:'short',year:'2-digit'});
    var cIdx=consData.findIndex(function(d){return d.m===mLabel;});
    if(cIdx>=0)consData[cIdx].kwh=kwh;else consData.push({m:mLabel,kwh:kwh});
    baseline=consData.reduce(function(s,d){return s+d.kwh;},0)/consData.length;
  }

  contractChecks=results.filter(function(r){return r.cat==='Tariff';}).map(function(r){
    return {label:r.name,contract:'see detail',billed:'see detail',vari:r.status==='pass'?'—':'variance found',status:r.status,detail:r.detail};
  });

  document.getElementById('validation-subtitle').textContent=invnum+' | '+acctref+' | '+supplier;
  document.getElementById('validation-real-banner').style.display='flex';

  document.getElementById('stat-errors').textContent=errN;
  document.getElementById('stat-warnings').textContent=warnN;
  document.getElementById('stat-passed').textContent=passN;
  document.getElementById('stat-overcharge').textContent=overcharge>0?money(overcharge):'£0.00';
  document.getElementById('tab-flagged-n').textContent=errN+warnN;
  document.getElementById('tab-errors-n').textContent=errN;
  document.getElementById('tab-warnings-n').textContent=warnN;
  document.getElementById('tab-passed-n').textContent=passN;

  renderDashboard();
  renderInvoiceLibrary();
  renderAccounts();
  renderConsumption();
  renderBilling();
  renderSpendStatus();
  updateGlobalStats();

  showPage('validation',null);
  switchTabByFilter('flagged');
}
</script>
</body>
</html>
