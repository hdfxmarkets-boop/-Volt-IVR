    <div style="font-size:11px;color:var(--tx3);margin-bottom:14px;line-height:1.6">A ready-to-send summary of the errors found on this invoice, addressed to your supplier. Edit as needed, then copy or download to send.</div>
    <div class="fgrp"><label>Recipient (supplier)</label><input type="text" id="reportSupplier" value="" onchange="refreshReport()"></div>
    <div class="fgrp"><label>Your reference</label><input type="text" id="reportAccount" value="" onchange="refreshReport()"></div>
    <textarea id="reportText" style="width:100%;min-height:340px;padding:14px;background:#141414;border:1px solid var(--bdr2);border-radius:8px;font-size:11.5px;color:var(--tx);font-family:'SF Mono',Menlo,monospace;line-height:1.7;resize:vertical;outline:none"></textarea>
    <div id="reportCopyMsg" style="display:none;font-size:11px;color:var(--g);margin-top:8px">✓ Copied to clipboard</div>
    <div class="modal-footer">
      <button class="btn btn-o" onclick="closeReportModal()">Close</button>
      <button class="btn btn-o" onclick="copyReport()">Copy to clipboard</button>
      <button class="btn btn-o" onclick="downloadReportTxt()">⬇ Download .txt</button>
      <button class="btn btn-g" onclick="downloadReportPDF()">⬇ Download PDF</button>
    </div>
  </div>
</div>

<script>
var checks=[];
var invoices=[];
var consData=[];
var baseline=0;
var accounts=[];
var contractChecks=[];
var networkLines=[];
var currentInvoiceMeta={invnum:'',acctref:'',supplier:''};
var lastOvercharge=0;

function bstat(s){
  if(s==='error') return '<span class="badge error">&#x2717; Error</span>';
  if(s==='warning') return '<span class="badge warning">&#x26A0; Warning</span>';
  return '<span class="badge pass">&#x2713; Pass</span>';
}

var allChecks=[];
var emptyState=function(icon,title,sub,ctaLabel,ctaFn){
  return '<div style="text-align:center;padding:32px 16px;color:var(--tx3)"><div style="font-size:26px;margin-bottom:8px">'+icon+'</div><div style="font-size:12px;font-weight:700;color:var(--tx2);margin-bottom:4px">'+title+'</div><div style="font-size:11px;line-height:1.6;max-width:320px;margin:0 auto 14px">'+sub+'</div>'+(ctaLabel?'<button class="btn btn-g" style="font-size:11px" onclick="'+ctaFn+'">'+ctaLabel+'</button>':'')+'</div>';
};

function updateGlobalStats(){
  var errN=0,warnN=0,passN=0,over=0;
  invoices.forEach(function(i){errN+=i.errors||0;warnN+=i.warnings||0;passN+=i.passed||0;over+=i.overcharge||0;});
  var set=function(id,v){var el=document.getElementById(id);if(el)el.textContent=v;};
  set('topbar-errors',errN);set('topbar-warnings',warnN);set('topbar-overcharge',money(over));
  set('dash-errors',errN);set('dash-warnings',warnN);set('dash-passed',passN);set('dash-overcharge',money(over));
  var alertBox=document.getElementById('dash-alert');
  if(alertBox){
    if(errN>0){
      alertBox.innerHTML='<div class="alert error"><span style="font-size:14px;flex-shrink:0">🚨</span><div><strong>Action needed:</strong> '+errN+' error'+(errN===1?'':'s')+' found across your validated invoices — estimated recoverable overcharge <strong>'+money(over)+'</strong>. <a href="#" onclick="showPage(\'validation\',null);return false" style="color:var(--g);font-weight:700">Review now →</a></div></div>';
    } else {
      alertBox.innerHTML='';
    }
  }
}

function renderDashboard(){
  var ri=document.getElementById('recent-inv');
  if(!invoices.length){
    ri.innerHTML=emptyState('📤','No invoices yet','Upload a real invoice and run validation to see it appear here.','Upload Documents',"showPage('upload',null)");
  } else {
    ri.innerHTML=invoices.slice(0,4).map(function(i){
      var badge=i.errors>0?'<span class="ec">&#x26A0; '+i.errors+' err</span>':i.warnings>0?'<span class="badge warning">'+i.warnings+' warn</span>':'<span class="badge pass">&#x2713;</span>';
      return '<div class="ir" onclick="showPage(\'validation\',null)"><div class="ii '+i.type+'">'+i.icon+'</div><div class="in_"><div class="n">'+i.id+' — '+i.site+'</div><div class="m">'+i.supplier+' · '+i.date+'</div></div><div class="ia">'+i.amount+'</div>'+badge+'</div>';
    }).join('');
  }
  var cs=document.getElementById('cat-summary');
  if(!allChecks.length){
    cs.innerHTML=emptyState('🧮','No checks run yet','Category coverage will appear here once you run your first validation.',null,null);
  } else {
    var cats={};
    allChecks.forEach(function(c){cats[c.cat]=cats[c.cat]||{total:0,errors:0,warnings:0};cats[c.cat].total++;if(c.status==='error')cats[c.cat].errors++;if(c.status==='warning')cats[c.cat].warnings++;});
    cs.innerHTML=Object.keys(cats).map(function(catName){
      var c=cats[catName];
      var p=Math.round(((c.total-c.errors-c.warnings)/c.total)*100);
      var cls=c.errors>0?'red':c.warnings>0?'amb':'grn';
      return '<div style="margin-bottom:11px"><div style="display:flex;justify-content:space-between;margin-bottom:3px"><span style="font-size:11px;color:var(--tx)">'+catName+'</span><span style="font-size:10px;color:var(--tx3)">'+(c.total-c.errors-c.warnings)+'/'+c.total+'</span></div><div class="pb"><div class="pf '+cls+'" style="width:'+p+'%"></div></div></div>';
    }).join('');
  }
}


function renderInvoiceLibrary(){
  var el=document.getElementById('inv-library');
  if(!invoices.length){
    el.innerHTML=emptyState('📄','Invoice library is empty','Every invoice you upload and validate will be listed here.','Upload Documents',"showPage('upload',null)");
    return;
  }
  el.innerHTML=invoices.map(function(i){
    var e=i.errors>0?'<span class="ec">&#x26A0; '+i.errors+' errors</span>':'';
    var w=i.warnings>0?'<span class="badge warning" style="margin-left:4px">'+i.warnings+' warn</span>':'';
    var p=(i.errors===0&&i.warnings===0)?'<span class="badge pass">&#x2713; Pass</span>':'';
    return '<div class="ir" onclick="showPage(\'validation\',null)"><div class="ii '+i.type+'">'+i.icon+'</div><div class="in_"><div class="n">'+i.id+' — '+i.site+'</div><div class="m">'+i.supplier+' · '+i.date+'</div></div><div class="ia">'+i.amount+'</div>'+e+w+p+'</div>';
  }).join('');
}

function renderChecks(filter){
  var head=document.getElementById('check-table-head');
  var alertBox=document.getElementById('validation-alert');
  if(!checks.length){
    head.innerHTML='<tr><th>Status</th></tr>';
    alertBox.innerHTML='<span style="font-size:14px;flex-shrink:0">🔍</span><div>No validation has been run yet. Go to <strong>Upload Documents</strong>, confirm the invoice figures, and click Run Validation to see real results here.</div>';
    document.getElementById('check-table').innerHTML='<tr><td>'+emptyState('🧮','No results yet','Run a validation from the Upload Documents page to populate this table.','Upload Documents',"showPage('upload',null)")+'</td></tr>';
    return;
  }
  if(filter==='passed'){
    head.innerHTML='<tr><th>Category</th><th>Result</th><th>Coverage</th></tr>';
    var passN=checks.filter(function(c){return c.status==='pass';}).length;
    alertBox.innerHTML='<span style="font-size:14px;flex-shrink:0">✓</span><div>'+passN+' check'+(passN===1?'':'s')+' on this invoice matched expectations with no issues found.</div>';
    var cats={};
    checks.forEach(function(c){cats[c.cat]=cats[c.cat]||{total:0,passed:0};cats[c.cat].total++;if(c.status==='pass')cats[c.cat].passed++;});
    document.getElementById('check-table').innerHTML=Object.keys(cats).map(function(cat){
      var c=cats[cat];
      var pct=Math.round((c.passed/c.total)*100);
      return '<tr><td style="font-weight:600;color:var(--tx)">'+cat+'</td><td>'+bstat(c.passed===c.total?'pass':'warning')+'</td><td style="min-width:200px"><div style="display:flex;align-items:center;gap:10px"><div class="pb" style="flex:1"><div class="pf '+(c.passed===c.total?'grn':'amb')+'" style="width:'+pct+'%"></div></div><span style="font-size:10px;color:var(--tx3);white-space:nowrap">'+c.passed+'/'+c.total+'</span></div></td></tr>';
    }).join('');
    return;
  }
  head.innerHTML='<tr><th>#</th><th>Status</th><th>What we found</th></tr>';
  var passCount=checks.filter(function(c){return c.status==='pass';}).length;
  alertBox.innerHTML='<span style="font-size:14px;flex-shrink:0">🔍</span><div>Results below are calculated from the figures you confirmed on Upload Documents. <strong>'+passCount+' check'+(passCount===1?'':'s')+' passed</strong> with no issues.</div>';
  var rows=checks.filter(function(c){return c.status==='error'||c.status==='warning';});
  if(filter==='errors') rows=rows.filter(function(c){return c.status==='error';});
  else if(filter==='warnings') rows=rows.filter(function(c){return c.status==='warning';});
  document.getElementById('check-table').innerHTML=rows.length?rows.map(function(c){
    return '<tr class="check-row '+c.status+'"><td style="font-size:10px;color:var(--tx3);font-weight:700">'+c.id+'</td><td>'+bstat(c.status)+'</td><td style="font-size:12px;color:var(--tx2);line-height:1.6;padding-top:11px;padding-bottom:11px">'+c.detail+'</td></tr>';
  }).join(''):'<tr><td colspan="3">'+emptyState('✓','Nothing in this filter','No checks matched this filter for the current invoice.',null,null)+'</td></tr>';
}

var consumptionFilter='all';
function renderConsumption(){
  var chartEl=document.getElementById('cons-chart');
  if(!consData.length){
    chartEl.innerHTML='';
    document.getElementById('cons-table').innerHTML='<tr><td colspan="4">'+emptyState('📈','No consumption data yet','Each validated invoice with an invoice date adds a monthly consumption point here.','Upload Documents',"showPage('upload',null)")+'</td></tr>';
    return;
  }
  var max=0;
  for(var i=0;i<consData.length;i++){if(consData[i].kwh>max)max=consData[i].kwh;}
  var rows=consData.map(function(d){
    var pct=(d.kwh/max)*100;
    var dev=baseline?((d.kwh-baseline)/baseline)*100:0;
    var cls=Math.abs(dev)>20?'anomaly':Math.abs(dev)>12?'warnb':'normal';
    var tcls=Math.abs(dev)>20?'error':Math.abs(dev)>12?'warning':'pass';
    return {m:d.m,kwh:d.kwh,pct:pct,dev:dev,cls:cls,tcls:tcls};
  });
  var chartHtml=rows.map(function(r){
    return '<div class="bar-wrap"><div class="bar '+r.cls+'" style="height:'+Math.round(r.pct)+'px"></div><div class="bar-label">'+r.m.split(' ')[0]+'</div></div>';
  }).join('');
  chartEl.innerHTML=chartHtml;
  renderConsumptionTable(rows);
}
function renderConsumptionTable(rows){
  if(!consData.length){
    document.getElementById('cons-table').innerHTML='<tr><td colspan="4">'+emptyState('📈','No consumption data yet','Each validated invoice with an invoice date adds a monthly consumption point here.',null,null)+'</td></tr>';
    return;
  }
  rows=rows||(function(){
    var max=0;for(var i=0;i<consData.length;i++){if(consData[i].kwh>max)max=consData[i].kwh;}
    return consData.map(function(d){var dev=baseline?((d.kwh-baseline)/baseline)*100:0;var tcls=Math.abs(dev)>20?'error':Math.abs(dev)>12?'warning':'pass';return {m:d.m,kwh:d.kwh,dev:dev,tcls:tcls};});
  })();
  var filtered=rows;
  var tag=document.getElementById('cons-filter-tag');
  var label=document.getElementById('cons-filter-label');
  if(consumptionFilter==='flagged'){
    filtered=rows.filter(function(r){return r.tcls!=='pass';});
    tag.style.display='flex';label.textContent='Anomalies only ('+filtered.length+')';
  }else if(consumptionFilter==='largest'){
    filtered=rows.slice().sort(function(a,b){return Math.abs(b.dev)-Math.abs(a.dev);}).slice(0,1);
    tag.style.display='flex';label.textContent='Largest deviation';
  }else{
    tag.style.display='none';
  }
  document.getElementById('cons-table').innerHTML=filtered.map(function(r){
    var col=r.tcls==='error'?'var(--red)':r.tcls==='warning'?'var(--amb)':'var(--g)';
    var fw=r.tcls!=='pass'?'700':'400';
    var sign=r.dev>0?'+':'';
    return '<tr><td style="color:var(--tx)">'+r.m+'</td><td style="font-weight:600;color:var(--tx)">'+r.kwh.toLocaleString()+'</td><td style="color:'+col+';font-weight:'+fw+'">'+sign+r.dev.toFixed(1)+'%</td><td>'+bstat(r.tcls)+'</td></tr>';
  }).join('');
}
function filterConsumption(type){
  consumptionFilter=type;
  renderConsumptionTable();
  var t=document.getElementById('cons-table');
  if(t)t.closest('.card').scrollIntoView({behavior:'smooth',block:'center'});
}

var billingFilter='all';
function renderBilling(){
  renderBillingLists();
}
function renderBillingLists(){
  var cTag=document.getElementById('contract-filter-tag'),cLabel=document.getElementById('contract-filter-label');
  var nTag=document.getElementById('network-filter-tag'),nLabel=document.getElementById('network-filter-label');
  var cRows=contractChecks,nRows=networkLines;
  var labelText='';
  if(billingFilter==='pass'){cRows=contractChecks.filter(function(c){return c.status==='pass';});nRows=networkLines.filter(function(n){return n.status==='pass';});labelText='Passed only';}
  else if(billingFilter==='error'){cRows=contractChecks.filter(function(c){return c.status==='error';});nRows=networkLines.filter(function(n){return n.status==='error';});labelText='Errors only';}
  else if(billingFilter==='warning'){cRows=contractChecks.filter(function(c){return c.status==='warning';});nRows=networkLines.filter(function(n){return n.status==='warning';});labelText='Needs review';}
  else if(billingFilter==='flagged'){cRows=contractChecks.filter(function(c){return c.status!=='pass';});nRows=networkLines.filter(function(n){return n.status!=='pass';});labelText='Errors & warnings';}
  if(billingFilter==='all'){cTag.style.display='none';nTag.style.display='none';}
  else{
    cTag.style.display=cRows.length?'flex':'none';cLabel.textContent=labelText+' ('+cRows.length+')';
    nTag.style.display=nRows.length?'flex':'none';nLabel.textContent=labelText+' ('+nRows.length+')';
  }
  var allRows=contractChecks.concat(networkLines);
  var passN=allRows.filter(function(r){return r.status==='pass';}).length;
  var errN=allRows.filter(function(r){return r.status==='error';}).length;
  var warnN=allRows.filter(function(r){return r.status==='warning';}).length;
  document.getElementById('billing-passed').textContent=passN;
  document.getElementById('billing-errors').textContent=errN;
  document.getElementById('billing-warnings').textContent=warnN;
  document.getElementById('billing-overcharge').textContent=money(lastOvercharge);
  var banner=document.getElementById('billing-contract-alert');
  if(currentInvoiceMeta.supplier&&contractChecks.length){
    banner.style.display='flex';
    banner.innerHTML='<span style="font-size:14px;flex-shrink:0">📋</span><div>Showing contract checks for the most recently validated invoice — <strong>'+currentInvoiceMeta.invnum+'</strong> · '+currentInvoiceMeta.supplier+'.</div>';
  } else {
    banner.style.display='none';
  }
  document.getElementById('billing-contract').innerHTML=contractChecks.length?(cRows.map(function(c){
    var col=c.status==='error'?'var(--red)':c.status==='warning'?'var(--amb)':'var(--g)';
    return '<div class="contract-item"><div style="font-size:11px;color:var(--tx)">'+c.label+'</div><div style="font-size:11px;color:'+col+';line-height:1.5;max-width:420px">'+(c.detail||'')+'</div>'+bstat(c.status)+'</div>';
  }).join('')||'<div style="font-size:11px;color:var(--tx3);padding:8px 0">No items match this filter.</div>'):emptyState('📋','No contract checks yet','Upload a supply contract (or enter its rates manually) on the Upload Documents page, then run validation.','Upload Documents',"showPage('upload',null)");
  document.getElementById('billing-network').innerHTML=networkLines.length?nRows.map(function(n){
    var col=n.status==='error'?'var(--red)':n.status==='warning'?'var(--amb)':'var(--g)';
    return '<tr><td style="color:var(--tx);font-weight:500">'+n.type+'</td><td>'+n.billed+'</td><td>'+n.expected+'</td><td style="font-weight:700;color:'+col+'">'+n.vari+'</td><td>'+bstat(n.status)+'</td></tr>';
  }).join(''):'<tr><td colspan="5">'+emptyState('🔎','Network charge checks not yet available','This first version calculates billing, tariff and tax checks from your invoice and contract. Network/DUoS/TUoS charge checks need additional reference data not yet integrated.',null,null)+'</td></tr>';
}
function filterBilling(type){
  billingFilter=type;
  renderBillingLists();
  var t=document.getElementById('billing-contract');
  if(t)t.closest('.card').scrollIntoView({behavior:'smooth',block:'center'});
}

function renderAccounts(){
  if(!accounts.length){
    document.getElementById('account-table').innerHTML='<tr><td colspan="8">'+emptyState('🗂️','No sites yet','Sites are added automatically from each invoice you validate.','Upload Documents',"showPage('upload',null)")+'</td></tr>';
    return;
  }
  document.getElementById('account-table').innerHTML=accounts.map(function(a){
    return '<tr><td style="font-weight:700;color:var(--g)">'+a.ref+'</td><td style="color:var(--tx)">'+a.site+'</td><td style="font-family:monospace;font-size:10px">'+a.mpan+'</td><td>'+a.type+'</td><td>'+a.supplier+'</td><td><span class="badge info">'+a.tariff+'</span></td><td><span class="badge purple">'+a.contract+'</span></td><td><span class="badge '+(a.status==='Active'?'pass':'error')+'">'+a.status+'</span></td></tr>';
  }).join('');
}

function buildReportText(){
  var supplier=document.getElementById('reportSupplier').value||'your supplier';
  var ref=document.getElementById('reportAccount').value||'';
  var errors=checks.filter(function(c){return c.status==='error';});
  var warnings=checks.filter(function(c){return c.status==='warning';});
  var today=new Date().toLocaleDateString('en-GB',{day:'numeric',month:'long',year:'numeric'});
  var t='';
  t+='To: '+supplier+'\n';
  t+='Date: '+today+'\n';
  t+='Re: Billing dispute — '+ref+'\n\n';
  t+='Dear Sir/Madam,\n\n';
  t+='We have reviewed the above invoice and identified a number of discrepancies against our supply contract, applicable network charges and consumption records. We request that these are investigated, and that a corrected invoice, refund or credit is issued where an overcharge is confirmed.\n\n';
  t+='CONFIRMED ERRORS ('+errors.length+')\n';
  t+='These items do not match our contracted rates, meter data or billing rules and require correction:\n\n';
  errors.forEach(function(c,i){t+=(i+1)+'. '+c.detail+'\n';});
  if(warnings.length){
    t+='\nITEMS REQUIRING CLARIFICATION ('+warnings.length+')\n';
    t+='These items appear inconsistent with our records and we would appreciate confirmation or correction:\n\n';
    warnings.forEach(function(c,i){t+=(i+1)+'. '+c.detail+'\n';});
  }
  t+='\nEstimated overcharge identified: '+money(lastOvercharge)+'\n\n';
  t+='Please could you confirm receipt of this dispute and provide a response, including a corrected invoice and/or refund where applicable, within 10 working days.\n\n';
  t+='Yours faithfully,\n';
  t+='James Davies\n';
  t+='On behalf of the account holder';
  return t;
}
function openSupplierReport(){
  document.getElementById('reportSupplier').value=currentInvoiceMeta.supplier||'';
  document.getElementById('reportAccount').value=(currentInvoiceMeta.acctref||'')+(currentInvoiceMeta.invnum?' · Invoice '+currentInvoiceMeta.invnum:'');
  document.getElementById('reportText').value=buildReportText();
  document.getElementById('reportCopyMsg').style.display='none';
  document.getElementById('reportModal').classList.add('open');
}
function closeReportModal(){document.getElementById('reportModal').classList.remove('open');}
function refreshReport(){document.getElementById('reportText').value=buildReportText();}
function copyReport(){
  var ta=document.getElementById('reportText');
  ta.select();
  navigator.clipboard&&navigator.clipboard.writeText(ta.value);
  document.getElementById('reportCopyMsg').style.display='block';
  setTimeout(function(){document.getElementById('reportCopyMsg').style.display='none';},2500);
}
function downloadReportTxt(){
  var blob=new Blob([document.getElementById('reportText').value],{type:'text/plain'});
  var a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download='VoltIVR-Dispute-Report.txt';
  a.click();
}
function downloadReportPDF(){
  var jsPDF=window.jspdf.jsPDF;
  var doc=new jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
  var W=doc.internal.pageSize.getWidth();
  doc.setFillColor(8,8,8);doc.rect(0,0,W,30,'F');
  doc.setFillColor(82,176,67);doc.rect(0,28,W,2,'F');
  doc.setTextColor(255,255,255);doc.setFontSize(13);doc.setFont('helvetica','bold');
  doc.text('VOLT IVR',14,13);
  doc.setFontSize(7.5);doc.setFont('helvetica','normal');doc.setTextColor(160,160,160);
  doc.text('Billing dispute report — by Unitech International',14,20);
  var lines=doc.splitTextToSize(document.getElementById('reportText').value,182);
  var y=42;doc.setTextColor(30,30,30);doc.setFontSize(9.5);doc.setFont('courier','normal');
  for(var i=0;i<lines.length;i++){
    if(y>282){doc.addPage();y=20;}
    doc.text(lines[i],14,y);
    y+=5;
  }
  doc.save('VoltIVR-Dispute-Report.pdf');
}

function renderSpendStatus(){
  var lines=contractChecks.concat(networkLines);
  var errCount=lines.filter(function(l){return l.status==='error';}).length;
  var warnCount=lines.filter(function(l){return l.status==='warning';}).length;
  var el={verdict:document.getElementById('spend-verdict'),sub:document.getElementById('spend-sub'),detail:document.getElementById('spend-detail'),cta:document.getElementById('spend-cta'),bar:document.getElementById('spend-status-bar')};
  var verdict,color,sub,detail,ctaLabel,ctaFn;
  if(!invoices.length){
    verdict='No data yet';color='var(--tx3)';
    sub='Upload your first invoice to get started';
    detail='Once you upload a real invoice (and ideally your supply contract) and run validation, this card will tell you whether your spend is in line with your contract, needs review, or shows signs of overcharging.';
    ctaLabel='📤 Upload Documents';ctaFn="showPage('upload',null)";
  }else if(errCount>=3){
    verdict='Overspending';color='var(--red)';
    sub=errCount+' rate mismatches · '+warnCount+' to review';
    detail='Multiple charges on this invoice are billed above your contracted and published network rates. Based on current findings, you are likely on unfavourable terms or being incorrectly billed against your contract. We recommend disputing these charges with your supplier and requesting a corrected invoice and refund.';
    ctaLabel='📄 Generate Supplier Report';ctaFn='openSupplierReport()';
  }else if(errCount>=1||warnCount>=2){
    verdict='Elevated spend';color='var(--amb)';
    sub=errCount+' rate mismatches · '+warnCount+' to review';
    detail='Some charges are running above your contracted rates, though not yet at a level we would flag as clear overspending. We recommend requesting a rate review from your supplier to confirm these are being billed correctly.';
    ctaLabel='🔎 Review billing checks';ctaFn="showPage('billing',null)";
  }else{
    verdict='In line with contract';color='var(--g)';
    sub=lines.length+' contract & network checks passed';
    detail='Your billed rates are consistent with your agreed contract and published network charges. No action is needed at this time — we\'ll keep monitoring every new invoice automatically.';
    ctaLabel='🔎 View billing checks';ctaFn="showPage('billing',null)";
  }
  el.verdict.textContent=verdict;el.verdict.style.color=color;
  el.sub.textContent=sub;
